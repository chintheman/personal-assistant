# Personal Assistant — Environment Config
# Copy this file to .env and fill in your values

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
PA_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (message @userinfobot to get it)
PA_CHAT_ID=your_chat_id_here

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Model-agnostic via LiteLLM — swap any time, no code changes needed
PA_LLM_MODEL=claude-haiku-3-5

# Set the API key for whichever provider you use:
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=...   (use model=gpt-4o-mini)
# DEEPSEEK_API_KEY=... (use model=deepseek/deepseek-chat)

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Run scripts/setup_google_auth.py once to generate token.json
GOOGLE_CALENDAR_CREDS_PATH=credentials/google_credentials.json
GOOGLE_TOKEN_PATH=credentials/token.json

# ─── Database ────────────────────────────────────────────────────────────────
PA_DB_PATH=data/pa.db

# ─── Timezone ────────────────────────────────────────────────────────────────
PA_TIMEZONE=Asia/Singapore
